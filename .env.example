# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# --- Phase 0: Database (Neon Postgres) ---
# From the Neon "Connect" panel. Copy BOTH connection strings:
#   DATABASE_URL = Connection pooling ON  (host has "-pooler") — used by the app
#   DIRECT_URL   = Connection pooling OFF (no "-pooler")       — used by migrations
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require"

# --- Phase 1: Auth (Better Auth) — added later ---
# BETTER_AUTH_SECRET="generate-a-long-random-string"
# BETTER_AUTH_URL="http://localhost:3000"

# --- Phase 3: File storage (Vercel Blob) — added later ---
# BLOB_READ_WRITE_TOKEN="vercel-blob-token"

# --- Phase 4: AI (Google Gemini / AI Studio) — added later ---
# GEMINI_API_KEY="your-ai-studio-key"
