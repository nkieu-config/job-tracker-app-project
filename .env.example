# Web app environment (copy to apps/web/.env)

# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require"

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET="generate-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# --- File storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# --- AI (Google Gemini) ---
# Server-only key used by Server Actions and Route Handlers. Never exposed to the browser.
GEMINI_API_KEY="your-gemini-api-key"
