    "sweep-rate-limits": "tsx --conditions=react-server scripts/sweep-rate-limits.mts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@google/genai": "^2.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.4.0",
    "@vercel/functions": "^3.7.5",
    "better-auth": "^1.6.14",
    "client-only": "^0.0.1",
    "geist": "^1.7.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.7",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2",
