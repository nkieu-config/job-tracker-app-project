    "seed": "tsx --conditions=react-server scripts/seed.mts",
    "screenshots": "tsx scripts/screenshots.mts",
    "record-demo": "tsx scripts/record-demo.mts",
    "social-preview": "tsx scripts/social-preview.mts",
